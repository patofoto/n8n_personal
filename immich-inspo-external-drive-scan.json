    "nodes": [
      {
        "parameters": {
          "content": "## Postgres Queries",
          "height": 688,
          "width": 560
        },
        "type": "n8n-nodes-base.stickyNote",
        "typeVersion": 1,
        "position": [
          -3952,
          -1008
        ],
        "id": "8fe56195-34b1-4ab7-b862-e61ffacd0e2a",
        "name": "Sticky Note"
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "WITH faces AS (\n  SELECT\n    af.id,\n    af.\"personId\",\n    NULLIF(TRIM(p.name), '') AS person_name,\n    CASE\n      WHEN af.\"personId\" IS NULL THEN 'no_person_recognized'\n      WHEN NULLIF(TRIM(p.name), '') IS NULL THEN 'person_unlabeled'\n      ELSE 'person_named'\n    END AS state\n  FROM asset_face af\n  LEFT JOIN person p ON p.id = af.\"personId\"\n)\n\nSELECT\n  label,\n  face_count\nFROM (\n  -- State counts (faces)\n  SELECT\n    state AS label,\n    COUNT(*) AS face_count\n  FROM faces\n  GROUP BY state\n\n  UNION ALL\n\n  -- Name counts (faces per person)\n  SELECT\n    person_name AS label,\n    COUNT(*) AS face_count\n  FROM faces\n  WHERE person_name IS NOT NULL\n  GROUP BY person_name\n\n  UNION ALL\n\n  -- ✅ Total distinct recognized people\n  SELECT\n    'recognized_people_total' AS label,\n    COUNT(DISTINCT \"personId\") AS face_count\n  FROM faces\n  WHERE person_name IS NOT NULL\n) combined\nORDER BY\n  face_count DESC,\n  label;",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          -3888,
          -512
        ],
        "id": "8e8104d0-285f-4a26-8658-e41715c6c2b3",
        "name": "People Count",
        "credentials": {
          "postgres": {
            "id": "iCHwiGkAcxUxHf4K",
            "name": "Immich Inspiration Postgres Database"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  table_name,\n  json_agg(\n    json_build_object(\n      'name', column_name,\n      'type', data_type\n    )\n    ORDER BY ordinal_position\n  ) AS columns\nFROM information_schema.columns\nWHERE table_schema = 'public'\nGROUP BY table_name\nORDER BY table_name;",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          -3888,
          -912
        ],
        "id": "2b36ba09-c96f-4e10-909f-a0a5ce5201c4",
        "name": "all tables + columns per table",
        "credentials": {
          "postgres": {
            "id": "iCHwiGkAcxUxHf4K",
            "name": "Immich Inspiration Postgres Database"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  a.id,\n  a.\"originalFileName\",\n  a.\"createdAt\"         AS imported_at,\n  a.\"fileCreatedAt\",\n  a.\"localDateTime\"     AS timeline_date,\n  ex.\"dateTimeOriginal\" AS exif_original_date,\n  ex.\"modifyDate\"       AS exif_modify_date,\n  ex.\"timeZone\"         AS exif_time_zone\nFROM asset a\nLEFT JOIN asset_exif ex\n  ON ex.\"assetId\" = a.id\nORDER BY a.\"createdAt\" DESC;",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          -3888,
          -704
        ],
        "id": "58144069-acdc-41e1-ac18-a0a1acf1478b",
        "name": "Important Dates to Study",
        "credentials": {
          "postgres": {
            "id": "iCHwiGkAcxUxHf4K",
            "name": "Immich Inspiration Postgres Database"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  a.id,\n  a.\"originalFileName\",\n  a.\"createdAt\"         AS imported_at,\n  a.\"localDateTime\"     AS timeline_date,\n  ex.\"dateTimeOriginal\" AS exif_original_date,\n\n  -- mismatch metrics (NULL if timeline_date is NULL)\n  (a.\"createdAt\" - a.\"localDateTime\") AS time_difference,\n  ABS(EXTRACT(EPOCH FROM (a.\"createdAt\" - a.\"localDateTime\"))) AS diff_seconds,\n  ROUND(ABS(EXTRACT(EPOCH FROM (a.\"createdAt\" - a.\"localDateTime\"))) / 3600, 2)  AS diff_hours,\n  ROUND(ABS(EXTRACT(EPOCH FROM (a.\"createdAt\" - a.\"localDateTime\"))) / 86400, 2) AS diff_days,\n\n  -- helpful label\n  CASE\n    WHEN a.\"localDateTime\" IS NULL THEN 'no_timeline_date'\n    WHEN ex.\"dateTimeOriginal\" IS NULL THEN 'no_exif'\n    ELSE 'exif_present'\n  END AS exif_status\n\nFROM asset a\nLEFT JOIN asset_exif ex\n  ON ex.\"assetId\" = a.id\n\nORDER BY\n  (a.\"localDateTime\" IS NULL) ASC,   -- puts NULL timeline_date last\n  diff_seconds DESC NULLS LAST;      -- biggest mismatch first",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          -3648,
          -704
        ],
        "id": "0448d635-7c6a-4abf-8335-3db9b34d8878",
        "name": "EXIF Date Difference from Timeline",
        "credentials": {
          "postgres": {
            "id": "iCHwiGkAcxUxHf4K",
            "name": "Immich Inspiration Postgres Database"
          }
        }
      },
      {
        "parameters": {},
        "type": "n8n-nodes-base.manualTrigger",
        "typeVersion": 1,
        "position": [
          -3264,
          -1280
        ],
        "id": "815b75bb-a627-4f15-b91f-bb203df75d94",
