      {
        "parameters": {
          "content": "## ExifTool use via SSH",
          "height": 304,
          "width": 528
        },
        "type": "n8n-nodes-base.stickyNote",
        "position": [
          -3936,
          -1344
        ],
        "typeVersion": 1,
        "id": "1d21267d-e9ac-4f47-a0a8-2d6dc69f6cfb",
        "name": "Sticky Note1"
      },
      {
        "parameters": {
          "authentication": "privateKey",
          "command": "OFFSET=0\nLIMIT=500\nDIR=\"/media/pato/Media_HD/Inspiration Board\"\nEXIF=\"/home/linuxbrew/.linuxbrew/bin/exiftool\"\n\nLIST=\"$(mktemp)\"\nfind \"$DIR\" -maxdepth 1 -type f \\( -iname \"*.jpg\" -o -iname \"*.jpeg\" -o -iname \"*.png\" -o -iname \"*.heic\" \\) \\\n  | sort \\\n  | sed -n \"$((OFFSET+1)),$((OFFSET+LIMIT))p\" > \"$LIST\"\n\n\"$EXIF\" -q -q -api MissingTagValue=\"\" -json -d \"%Y-%m-%dT%H:%M:%S\" \\\n  -SourceFile -FileType -MIMEType -FileSize -ImageWidth -ImageHeight \\\n  -DateTimeOriginal -CreateDate -ModifyDate -FileModifyDate \\\n  -@ \"$LIST\""
        },
        "type": "n8n-nodes-base.ssh",
        "typeVersion": 1,
        "position": [
          -3856,
          -1232
        ],
        "id": "ae38763b-9c07-43f2-8546-c9ec3bd3fdb4",
        "name": "Execute a command",
        "credentials": {
          "sshPrivateKey": {
            "id": "ssr7RR2HiglJLW6v",
            "name": "SSH Private Key"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "// SSH node output is one item like: { code, stdout, stderr }\nconst out = items[0].json.stdout;\n\n// stdout is a JSON string (exiftool -json). Parse it.\nconst arr = JSON.parse(out);\n\n// return one n8n item per file (best for downstream processing)\nreturn arr.map(o => ({\n  json: {\n    ...o,\n    best_date: o.DateTimeOriginal || o.CreateDate || o.ModifyDate || o.FileModifyDate,\n    best_date_source: o.DateTimeOriginal ? \"DateTimeOriginal\"\n      : o.CreateDate ? \"CreateDate\"\n      : o.ModifyDate ? \"ModifyDate\"\n      : \"FileModifyDate\",\n  }\n}));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -3600,
          -1232
        ],
        "id": "18bf2e41-b31c-4336-94e9-f2f909ae1317",
        "name": "Code in JavaScript"
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  a.\"originalFileName\",\n  a.\"createdAt\"     AS imported_at,\n  a.\"localDateTime\" AS timeline_date\nFROM asset a\nWHERE\n  a.\"createdAt\" >= date_trunc('day', now())\nORDER BY\n  a.\"createdAt\" DESC;",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,
        "position": [
          -3632,
          -912
        ],
        "id": "9bef6e2e-bf01-4211-8d7d-b15daa968815",
        "name": "Images Imported Today",
        "credentials": {
          "postgres": {
            "id": "iCHwiGkAcxUxHf4K",
            "name": "Immich Inspiration Postgres Database"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const lines = $json.stdout.trim().split('\\n');\nreturn lines.map(line => ({ line }));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -2896,
