          "command": "DIR=\"/media/pato/Media_HD/Inspiration Board\"\n\nprintf \"%-8s %-10s\\n\" \"COUNT\" \"EXTENSION\"\nprintf \"%-8s %-10s\\n\" \"--------\" \"----------\"\n\nfind \"$DIR\" -maxdepth 1 -type f \\\n  | sed -E 's/.*\\.([^.]+)$/\\1/' \\\n  | tr '[:upper:]' '[:lower:]' \\\n  | sort | uniq -c | sort -nr \\\n  | awk '{ printf \"%-8d %-10s\\n\", $1, $2 }'"
